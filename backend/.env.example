DJANGO_SETTINGS_MODULE=bidals.settings.prod
BIDALS_ENV=production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DATABASE_URL=postgres://user:password@host:5432/bidals
DATABASE_CONN_MAX_AGE=60
REDIS_URL=redis://host:6379/0
USE_REDIS_CACHE=True
FRONTEND_URL=https://app.example.com
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=True
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
BID_RATE_LIMIT_AUTHENTICATED_ATTEMPTS=10
BID_RATE_LIMIT_ANONYMOUS_ATTEMPTS=2
BID_RATE_LIMIT_WINDOW_SECONDS=60
BID_ANOMALY_REJECT_THRESHOLD=5
BID_ANOMALY_RATE_LIMIT_THRESHOLD=3
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=3
SCHEDULED_JOBS_CONFIGURED=False
EMAIL_NOTIFICATIONS_ENABLED=False
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=notifications@example.com
MEDIA_URL=/media/
MEDIA_ROOT=/app/media
LOT_IMAGE_MAX_UPLOAD_SIZE_MB=5
USE_S3=False
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_STORAGE_BUCKET_NAME=bidals-media
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False
BACKUP_PROVIDER=render
BACKUP_LAST_VERIFIED_AT=
BACKUP_LAST_RESTORE_TEST_AT=
PORT=8000
WEB_CONCURRENCY=3
