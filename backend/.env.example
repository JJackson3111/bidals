DJANGO_SETTINGS_MODULE=bidals.settings.prod
BIDALS_ENV=production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=bidals.onrender.com
# Backend API origin and frontend origin are different values.
# Local frontend example: http://localhost:3000
# Staging frontend example: https://bidals-1.onrender.com
# Production frontend example: https://app.bidals.com
FRONTEND_URL=https://app.bidals.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.bidals.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.bidals.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_CSRF_COOKIE_HTTPONLY=True
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_REFERRER_POLICY=same-origin
DJANGO_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=()
DJANGO_CONTENT_SECURITY_POLICY=
DJANGO_CONTENT_SECURITY_POLICY_REPORT_ONLY=True
DATABASE_URL=postgresql://bidals_user:replace-me@postgres-host/bidals
DATABASE_CONN_MAX_AGE=60
REDIS_URL=redis://host:6379/0
USE_REDIS_CACHE=false
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_CACHE_KEY_PREFIX=bidals
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGGING=True
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
ENABLE_RATE_LIMITING=True
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTRATION=5/minute
# Blank means use BID_RATE_LIMIT_AUTHENTICATED_ATTEMPTS / BID_RATE_LIMIT_ANONYMOUS_ATTEMPTS / BID_RATE_LIMIT_WINDOW_SECONDS.
RATE_LIMIT_BID_CREATE=
RATE_LIMIT_PASSWORD_RESET=3/hour
RATE_LIMIT_ADMIN_ACTIONS=30/minute
BID_RATE_LIMIT_AUTHENTICATED_ATTEMPTS=10
BID_RATE_LIMIT_ANONYMOUS_ATTEMPTS=2
BID_RATE_LIMIT_WINDOW_SECONDS=60
BID_ANOMALY_REJECT_THRESHOLD=5
BID_ANOMALY_RATE_LIMIT_THRESHOLD=3
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=3
SCHEDULED_JOBS_CONFIGURED=False
EMAIL_NOTIFICATIONS_ENABLED=False
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=notifications@example.com
MEDIA_URL=/media/
MEDIA_ROOT=/app/media
LOT_IMAGE_MAX_UPLOAD_SIZE_MB=5
SERVE_LOCAL_MEDIA=False
USE_S3=False
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_STORAGE_BUCKET_NAME=bidals-media
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_CACHE_CONTROL=max-age=86400
BACKUP_PROVIDER=render
BACKUP_LAST_VERIFIED_AT=
BACKUP_LAST_RESTORE_TEST_AT=
STAGING_ADMIN_PASSWORD=
PORT=8000
WEB_CONCURRENCY=3
